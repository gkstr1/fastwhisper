---
interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="Learn technical recruiting with Top Recruiter Academy" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body>
		<nav>
			<div class="nav-content">
				<a href="/" class="logo">Top Recruiter Academy</a>
				<button class="mobile-menu-button" aria-label="Toggle menu">
					<span></span>
					<span></span>
					<span></span>
				</button>
				<div class="nav-links">
					<a href="/courses">Course</a>
					<a href="/resources">Resources</a>
					<a href="/blog">Blog</a>
					<a href="/about">About</a>
				</div>
				<div class="auth-buttons">
					<a href="/login" class="login">Log In</a>
					<a href="/signup" class="signup">Sign Up</a>
				</div>
			</div>
		</nav>
		<slot />
		<footer>
			<div class="footer-content">
				<div class="footer-section">
					<h3>Top Recruiter Academy</h3>
					<p>Empowering technical recruiters with knowledge and skills</p>
				</div>
				<div class="footer-section">
					<h4>Quick Links</h4>
					<a href="/courses">Course</a>
					<a href="/resources">Resources</a>
					<a href="/blog">Blog</a>
					<a href="/about">About</a>
				</div>
				<div class="footer-section">
					<h4>Contact</h4>
					<a href="mailto:hello@toprecruiteracademy.com">hello@toprecruiteracademy.com</a>
				</div>
			</div>
			<div class="footer-bottom">
				<p>&copy; 2024 Top Recruiter Academy. All rights reserved.</p>
			</div>
		</footer>
	</body>
</html>

<style is:global>
	:root {
		--accent: 136, 58, 234;
		--accent-light: 224, 204, 250;
		--accent-dark: 49, 10, 101;
		--accent-gradient: linear-gradient(
			45deg,
			rgb(var(--accent)),
			rgb(var(--accent-light)) 30%,
			white 60%
		);
	}
	html {
		font-family: system-ui, sans-serif;
		background: #13151a;
		scroll-behavior: smooth;
	}
	body {
		margin: 0;
		padding: 0;
		min-height: 100vh;
		display: flex;
		flex-direction: column;
	}
	nav {
		background: rgba(19, 21, 26, 0.8);
		backdrop-filter: blur(10px);
		position: sticky;
		top: 0;
		z-index: 1000;
		padding: 1rem 0;
		border-bottom: 1px solid rgba(var(--accent-light), 0.1);
	}
	.nav-content {
		max-width: 1200px;
		margin: 0 auto;
		padding: 0 1rem;
		display: flex;
		justify-content: space-between;
		align-items: center;
	}
	.logo {
		color: white;
		text-decoration: none;
		font-size: 1.5rem;
		font-weight: bold;
	}
	.mobile-menu-button {
		display: none;
		background: none;
		border: none;
		cursor: pointer;
		padding: 0.5rem;
	}
	.mobile-menu-button span {
		display: block;
		width: 25px;
		height: 3px;
		background-color: white;
		margin: 5px 0;
		transition: 0.3s;
	}
	.nav-links {
		display: flex;
		gap: 2rem;
	}
	.nav-links a {
		color: white;
		text-decoration: none;
		transition: color 0.3s ease;
	}
	.nav-links a:hover {
		color: rgb(var(--accent-light));
	}
	.auth-buttons {
		display: flex;
		gap: 1rem;
	}
	.auth-buttons a {
		padding: 0.5rem 1rem;
		border-radius: 4px;
		text-decoration: none;
		transition: all 0.3s ease;
	}
	.login {
		color: rgb(var(--accent-light));
		border: 1px solid rgb(var(--accent-light));
	}
	.signup {
		background: rgb(var(--accent));
		color: white;
	}
	.login:hover {
		background: rgba(var(--accent-light), 0.1);
	}
	.signup:hover {
		background: rgb(var(--accent-dark));
	}
	footer {
		margin-top: auto;
		background: rgba(19, 21, 26, 0.95);
		padding: 4rem 0 1rem;
		border-top: 1px solid rgba(var(--accent-light), 0.1);
	}
	.footer-content {
		max-width: 1200px;
		margin: 0 auto;
		padding: 0 1rem;
		display: grid;
		grid-template-columns: 2fr 1fr 1fr;
		gap: 2rem;
		color: white;
	}
	.footer-section h3 {
		color: rgb(var(--accent-light));
		margin: 0 0 1rem;
	}
	.footer-section h4 {
		color: rgb(var(--accent-light));
		margin: 0 0 1rem;
	}
	.footer-section a {
		color: white;
		text-decoration: none;
		display: block;
		margin-bottom: 0.5rem;
		transition: color 0.3s ease;
	}
	.footer-section a:hover {
		color: rgb(var(--accent-light));
	}
	.footer-bottom {
		max-width: 1200px;
		margin: 2rem auto 0;
		padding: 1rem;
		border-top: 1px solid rgba(var(--accent-light), 0.1);
		text-align: center;
		color: rgba(255, 255, 255, 0.6);
	}

	@media (max-width: 768px) {
		.mobile-menu-button {
			display: block;
		}
		.nav-links, .auth-buttons {
			display: none;
		}
		.nav-links.active, .auth-buttons.active {
			display: flex;
			flex-direction: column;
			position: absolute;
			top: 100%;
			left: 0;
			right: 0;
			background: rgba(19, 21, 26, 0.95);
			padding: 1rem;
		}
		.footer-content {
			grid-template-columns: 1fr;
			text-align: center;
		}
		h1 {
			font-size: 2.5rem !important;
		}
		.tagline {
			font-size: 1.2rem !important;
		}
	}
</style>

<script>
	const mobileMenuButton = document.querySelector('.mobile-menu-button');
	const navLinks = document.querySelector('.nav-links');
	const authButtons = document.querySelector('.auth-buttons');

	mobileMenuButton?.addEventListener('click', () => {
		navLinks?.classList.toggle('active');
		authButtons?.classList.toggle('active');
	});
</script>